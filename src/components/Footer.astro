---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href={`${base}/`} class="footer-logo">🤖 AI<strong>Tools</strong>Hub</a>
      <p class="footer-tagline">Honest, independent AI tool reviews.<br/>We test so you don't waste money.</p>
    </div>

    <div class="footer-links">
      <div class="footer-col">
        <h4>Reviews</h4>
        <a href={`${base}/blog`}>All Reviews</a>
        <a href={`${base}/blog/best-ai-writing-tools-2026`}>AI Writing</a>
        <a href={`${base}/blog/best-ai-coding-assistants-2026`}>AI Coding</a>
        <a href={`${base}/blog/best-ai-image-generators-2026`}>AI Images</a>
      </div>
      <div class="footer-col">
        <h4>Compare</h4>
        <a href={`${base}/blog/chatgpt-vs-claude-2026`}>ChatGPT vs Claude</a>
        <a href={`${base}/blog/cursor-vs-github-copilot-2026`}>Cursor vs Copilot</a>
        <a href={`${base}/blog/midjourney-vs-dalle-3-2026`}>Midjourney vs DALL-E</a>
        <a href={`${base}/compare`}>All Comparisons</a>
      </div>
      <div class="footer-col">
        <h4>Site</h4>
        <a href={`${base}/`}>Home</a>
        <a href={`${base}/tools`}>Top Tools</a>
        <a href={`${base}/about`}>About</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p>© {year} AIToolsHub. All rights reserved. | Contains affiliate links — we may earn a commission at no extra cost to you.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: #1a1a2e;
    color: #a0aec0;
    margin-top: 4rem;
  }
  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1.5rem 2rem;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
  }
  .footer-logo {
    font-size: 1.2rem;
    font-weight: 700;
    color: white;
    text-decoration: none;
  }
  .footer-logo strong { color: #a78bfa; }
  .footer-tagline {
    margin: 0.75rem 0 0;
    font-size: 0.85rem;
    line-height: 1.6;
    color: #718096;
  }
  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .footer-col h4 {
    color: white;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.75rem;
  }
  .footer-col a {
    display: block;
    color: #718096;
    text-decoration: none;
    font-size: 0.85rem;
    padding: 0.2rem 0;
    transition: color 0.15s;
  }
  .footer-col a:hover { color: #a78bfa; }
  .footer-bottom {
    border-top: 1px solid #2d3748;
    text-align: center;
    padding: 1.2rem 1.5rem;
    font-size: 0.78rem;
    color: #4a5568;
  }
  @media (max-width: 720px) {
    .footer-inner { grid-template-columns: 1fr; gap: 2rem; }
    .footer-links { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .footer-links { grid-template-columns: 1fr; }
  }
</style>
