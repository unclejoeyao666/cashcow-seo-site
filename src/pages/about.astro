---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead title="About AIToolsHub — Our Mission & Review Process" description="Learn how AIToolsHub reviews AI tools. Independent, honest, no paid placements." />
  <style>
    .about-hero {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 4rem 1.5rem 3rem;
      text-align: center;
    }
    .about-hero h1 { font-size: clamp(1.6rem, 4vw, 2.4rem); color: white; margin: 0 0 0.75rem; }
    .about-hero p { opacity: 0.9; max-width: 560px; margin: 0 auto; font-size: 1.05rem; }

    .container {
      max-width: 780px;
      margin: 0 auto;
      padding: 3rem 1.5rem 5rem;
    }

    .section { margin-bottom: 3rem; }
    .section h2 { font-size: 1.4rem; font-weight: 800; margin: 0 0 1rem; color: #1a1a2e; }
    .section p { color: #4b5563; line-height: 1.8; margin: 0 0 0.75rem; }

    .values-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin-top: 1.5rem;
    }
    .value-card {
      background: #faf5ff;
      border: 1px solid #e9d5ff;
      border-radius: 12px;
      padding: 1.4rem;
    }
    .value-card .icon { font-size: 1.8rem; display: block; margin-bottom: 0.5rem; }
    .value-card h3 { font-size: 0.95rem; font-weight: 700; margin: 0 0 0.3rem; color: #4c1d95; }
    .value-card p { font-size: 0.83rem; color: #6b7280; margin: 0; line-height: 1.5; }

    .process-steps { list-style: none; padding: 0; margin: 1.5rem 0 0; }
    .process-steps li {
      display: flex;
      gap: 1rem;
      padding: 1rem 0;
      border-bottom: 1px solid #f3f4f6;
    }
    .step-num {
      width: 32px; height: 32px;
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 0.85rem;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .step-content h4 { font-size: 0.95rem; font-weight: 700; margin: 0 0 0.2rem; }
    .step-content p { font-size: 0.85rem; color: #6b7280; margin: 0; line-height: 1.5; }

    .disclaimer {
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      padding: 1.4rem;
      font-size: 0.85rem;
      color: #6b7280;
      line-height: 1.7;
    }
    .cta-row { text-align: center; margin-top: 3rem; }
    .btn { background: #7c3aed; color: white; padding: 0.85rem 2rem; border-radius: 8px; font-weight: 700; text-decoration: none; display: inline-block; }
  </style>
</head>
<body>
  <Header />

  <div class="about-hero">
    <h1>About AIToolsHub</h1>
    <p>We test AI tools so you don't waste money on the wrong ones. Independent reviews, zero paid placements.</p>
  </div>

  <div class="container">
    <div class="section">
      <h2>Our Mission</h2>
      <p>AIToolsHub exists because finding good AI tools is hard. Most "review" sites are just paid ads dressed up as editorial content. We're different: we actually use the tools, pay for subscriptions, and tell you what we find — good or bad.</p>
      <p>Our goal is to help individuals, freelancers, and small businesses make smart decisions with their AI tool budgets.</p>
    </div>

    <div class="section">
      <h2>Our Values</h2>
      <div class="values-grid">
        <div class="value-card">
          <span class="icon">🔍</span>
          <h3>Independent</h3>
          <p>No sponsored placements. Our rankings are based on testing, not payments.</p>
        </div>
        <div class="value-card">
          <span class="icon">🧪</span>
          <h3>Actually Tested</h3>
          <p>We use the tools ourselves. We pay for subscriptions. No secondhand reviews.</p>
        </div>
        <div class="value-card">
          <span class="icon">📅</span>
          <h3>Up to Date</h3>
          <p>AI moves fast. We update reviews when tools change significantly.</p>
        </div>
        <div class="value-card">
          <span class="icon">💰</span>
          <h3>ROI Focused</h3>
          <p>We always answer: is this tool worth the money? What's the real value?</p>
        </div>
      </div>
    </div>

    <div class="section">
      <h2>How We Review AI Tools</h2>
      <ul class="process-steps">
        <li>
          <div class="step-num">1</div>
          <div class="step-content">
            <h4>Sign up & use it for real</h4>
            <p>We create accounts, pay for plans, and use tools on real projects — not demos.</p>
          </div>
        </li>
        <li>
          <div class="step-num">2</div>
          <div class="step-content">
            <h4>Benchmark against alternatives</h4>
            <p>We compare output quality, speed, and value against direct competitors.</p>
          </div>
        </li>
        <li>
          <div class="step-num">3</div>
          <div class="step-content">
            <h4>Score on 5 dimensions</h4>
            <p>Features, ease of use, output quality, pricing, and support are scored independently.</p>
          </div>
        </li>
        <li>
          <div class="step-num">4</div>
          <div class="step-content">
            <h4>Publish honest findings</h4>
            <p>We share both pros and cons. If a tool isn't worth it, we say so clearly.</p>
          </div>
        </li>
        <li>
          <div class="step-num">5</div>
          <div class="step-content">
            <h4>Update when things change</h4>
            <p>Tool updates, pricing changes, and new features trigger review refreshes.</p>
          </div>
        </li>
      </ul>
    </div>

    <div class="section">
      <h2>Affiliate Disclosure</h2>
      <div class="disclaimer">
        Some links on AIToolsHub are affiliate links. This means if you click and make a purchase, we may earn a small commission — at no extra cost to you. This helps us keep the site running and reviews free. We only recommend tools we've personally tested and genuinely believe offer value. Our editorial opinions are never influenced by affiliate relationships.
      </div>
    </div>

    <div class="cta-row">
      <a href={`${base}/blog`} class="btn">Browse All Reviews →</a>
    </div>
  </div>

  <Footer />
</body>
</html>
